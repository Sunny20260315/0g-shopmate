{
  "name": "@shopmate/monorepo",
  "version": "1.0.0",
  "description": "Enterprise Web3 AI Agent Commerce Platform - Monorepo",
  "private": true,
  "license": "MIT",
  "author": "0G-ShopMate Team",
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:fs": "turbo dev --filter=frontend",
    "dev:bd": "turbo dev --filter=backend",
    "build": "turbo build",
    "build:fs": "turbo build --filter=frontend",
    "build:bd": "turbo build --filter=backend",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "clean": "turbo clean && rm -rf node_modules",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
